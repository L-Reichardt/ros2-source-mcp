{
  "name": "control_msgs",
  "version": "2.5.1",
  "description": "control_msgs contains base messages and actions useful for\n    controlling robots.  It provides representations for controller\n    setpoints and joint and cartesian trajectories.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://ros.org/wiki/control_msgs",
      "type": "website"
    }
  ],
  "repo": {
    "name": "control_msgs",
    "url": "https://github.com/ros-controls/control_msgs.git",
    "branch": "foxy-devel"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake",
      "rosidl_default_generators"
    ],
    "runtime": [
      "rosidl_default_runtime"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "build_and_runtime": [
      "action_msgs",
      "builtin_interfaces",
      "geometry_msgs",
      "std_msgs",
      "trajectory_msgs"
    ],
    "depended_on_by": [
      "control_toolbox",
      "gazebo_ros2_control_demos",
      "gazebo_ros2_control_demos",
      "gripper_controllers",
      "hardware_interface",
      "ign_ros2_control_demos",
      "ign_ros2_control_demos",
      "joint_state_broadcaster",
      "joint_trajectory_controller",
      "joy_teleop",
      "turtlebot3_manipulation_teleop",
      "webots_ros2_universal_robot"
    ]
