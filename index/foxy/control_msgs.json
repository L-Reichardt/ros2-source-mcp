    "SingleJointPosition": {
      "description": "",
      "raw": "float64 position\nbuiltin_interfaces/Duration min_duration\nfloat64 max_velocity\n---\n---\nstd_msgs/Header header\nfloat64 position\nfloat64 velocity\nfloat64 error\n",
      "goal_fields": [
        {
          "type": "float64",
