    "JogMultiAxis": {
      "description": "____________________________________________________________________________________________",
      "raw": "#____________________________________________________________________________________________\n# multi jog\n# multi jog speed = (250mm/s x 1.73) x unit vecter x speed [%] \n#____________________________________________________________________________________________\n\nfloat64[6]  jog_axis          # unit vecter of Task space [Tx, Ty, Tz, Rx, Ry, Rz] : -1.0 ~ +1.0 \nint8        move_reference    # 0 : MOVE_REFERENCE_BASE, 1 : MOVE_REFERENCE_TOOL, 2 : MOVE_REFERENCE_WORLD\nfloat64     speed             # jog speed [%]",
      "fields": [
        {
          "type": "float64[6]",
          "name": "jog_axis",
          "comment": "unit vecter of Task space [Tx, Ty, Tz, Rx, Ry, Rz] : -1.0 ~ +1.0",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8",
          "name": "move_reference",
          "comment": "0 : MOVE_REFERENCE_BASE, 1 : MOVE_REFERENCE_TOOL, 2 : MOVE_REFERENCE_WORLD",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "speed",
          "comment": "jog speed [%]",
          "default": null,
          "is_constant": false
        }
      ]
    },
