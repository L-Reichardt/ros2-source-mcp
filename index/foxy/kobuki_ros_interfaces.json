    "BumperEvent": {
      "description": "Provides a bumper event.",
      "raw": "# Provides a bumper event.\n# This message is generated whenever a particular bumper is pressed or released.\n# Note that, despite bumper field on SensorState messages, state field is not a\n# bitmask, but the new state of a single sensor.\n\n# bumper\nuint8 LEFT   = 0\nuint8 CENTER = 1\nuint8 RIGHT  = 2\n\n# state\nuint8 RELEASED = 0\nuint8 PRESSED  = 1\n\nuint8 bumper\nuint8 state\n",
      "fields": [
        {
          "type": "uint8",
          "name": "LEFT",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CENTER",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RIGHT",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RELEASED",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "PRESSED",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "bumper",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "state",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
