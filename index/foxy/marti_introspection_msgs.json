        },
        {
          "type": "bool",
          "name": "default_bool",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "max_value",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "min_value",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ServiceInfo": {
      "description": "This message contains documentation data about a service client/server in a node",
      "raw": "# This message contains documentation data about a service client/server in a node\n\n# The internal name of the service\nstring name\n\n# The external, global name of the service\nstring resolved_name\n\n# A human readable description of the service and how to use it\nstring description\n\n# Used to group related components\nstring group\n\n# The name of the message type\nstring message_type\n\n# If this is a service server, otherwise it is a service client\nbool server\n\n# Indicates if this is a topic service rather than a true service\nbool topic_service\n",
      "fields": [
        {
          "type": "string",
          "name": "name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "resolved_name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "description",
          "comment": "",
