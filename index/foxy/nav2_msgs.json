          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RESUME",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RESET",
          "comment": "",
          "default": "3",
