      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "SaveMap": {
      "description": "URL of map resource",
      "raw": "# URL of map resource\n# Can be an absolute path to a file: file:///path/to/maps/floor1.yaml\n# Or, relative to a ROS package: package://my_ros_package/maps/floor2.yaml\nstring map_topic\nstring map_url\n# Constants for image_format. Supported formats: pgm, png, bmp\nstring image_format\n# Map modes: trinary, scale or raw\nstring map_mode\n# Thresholds. Values in range of [0.0 .. 1.0]\nfloat32 free_thresh\nfloat32 occupied_thresh\n---\nbool result\n",
      "request_fields": [
        {
          "type": "string",
          "name": "map_topic",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "map_url",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "image_format",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "map_mode",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "free_thresh",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "occupied_thresh",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "result",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
