  "messages": {
    "BehaviorTreeLog": {
      "description": "",
      "raw": "builtin_interfaces/Time timestamp    # ROS time that this log message was sent.\nBehaviorTreeStatusChange[] event_log\n",
      "fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "timestamp",
          "comment": "ROS time that this log message was sent.",
          "default": null,
          "is_constant": false
        },
        {
          "type": "BehaviorTreeStatusChange[]",
          "name": "event_log",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "BehaviorTreeStatusChange": {
      "description": "",
      "raw": "builtin_interfaces/Time timestamp  # internal behavior tree event timestamp. Typically this is wall clock time\nstring node_name\nstring previous_status              # IDLE, RUNNING, SUCCESS or FAILURE\nstring current_status               # IDLE, RUNNING, SUCCESS or FAILURE\n",
      "fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "timestamp",
          "comment": "internal behavior tree event timestamp. Typically this is wall clock time",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "node_name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "previous_status",
          "comment": "IDLE, RUNNING, SUCCESS or FAILURE",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "current_status",
          "comment": "IDLE, RUNNING, SUCCESS or FAILURE",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Costmap": {
      "description": "This represents a 2-D grid map, in which each cell has an associated cost",
      "raw": "# This represents a 2-D grid map, in which each cell has an associated cost\n\nstd_msgs/Header header\n\n# MetaData for the map\nCostmapMetaData metadata\n\n# The cost data, in row-major order, starting with (0,0).\nuint8[] data\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "CostmapMetaData",
          "name": "metadata",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8[]",
          "name": "data",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "CostmapMetaData": {
      "description": "This hold basic information about the characteristics of the Costmap",
      "raw": "# This hold basic information about the characteristics of the Costmap\n\n# The time at which the static map was loaded\nbuiltin_interfaces/Time map_load_time\n\n# The time of the last update to costmap\nbuiltin_interfaces/Time update_time\n\n# The corresponding layer name\nstring layer\n\n# The map resolution [m/cell]\nfloat32 resolution\n\n# Number of cells in the horizontal direction\nuint32 size_x\n\n# Number of cells in the vertical direction\nuint32 size_y\n\n# The origin of the costmap [m, m, rad].\n# This is the real-world pose of the cell (0,0) in the map.\ngeometry_msgs/Pose origin\n",
      "fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "map_load_time",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "builtin_interfaces/Time",
          "name": "update_time",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "layer",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "resolution",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "size_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "size_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "geometry_msgs/Pose",
          "name": "origin",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Particle": {
      "description": "This represents an individual particle with weight produced by a particle filter",
      "raw": "# This represents an individual particle with weight produced by a particle filter\n\ngeometry_msgs/Pose pose\n\nfloat64 weight\n",
      "fields": [
        {
          "type": "geometry_msgs/Pose",
          "name": "pose",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "weight",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ParticleCloud": {
      "description": "This represents a particle cloud containing particle poses and weights",
      "raw": "# This represents a particle cloud containing particle poses and weights\n\nstd_msgs/Header header\n\n# Array of particles in the cloud\nParticle[] particles\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "Particle[]",
          "name": "particles",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "VoxelGrid": {
      "description": "",
      "raw": "std_msgs/Header header\nuint32[] data\ngeometry_msgs/Point32 origin\ngeometry_msgs/Vector3 resolutions\nuint32 size_x\nuint32 size_y\nuint32 size_z\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32[]",
          "name": "data",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "geometry_msgs/Point32",
          "name": "origin",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "geometry_msgs/Vector3",
          "name": "resolutions",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "size_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "size_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "size_z",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "services": {
    "ClearCostmapAroundRobot": {
      "description": "Clears the costmap within a window around the robot",
      "raw": "# Clears the costmap within a window around the robot\n\nfloat32 window_size_x\nfloat32 window_size_y\n---\nstd_msgs/Empty response\n",
      "request_fields": [
        {
          "type": "float32",
          "name": "window_size_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "window_size_y",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "std_msgs/Empty",
          "name": "response",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ClearCostmapExceptRegion": {
      "description": "Clears the costmap except a rectangular region specified by reset_distance",
      "raw": "# Clears the costmap except a rectangular region specified by reset_distance\n\nfloat32 reset_distance\n---\nstd_msgs/Empty response\n",
      "request_fields": [
        {
          "type": "float32",
          "name": "reset_distance",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "std_msgs/Empty",
          "name": "response",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ClearEntireCostmap": {
      "description": "Clears all layers on the costmap",
      "raw": "# Clears all layers on the costmap\n\nstd_msgs/Empty request\n---\nstd_msgs/Empty response\n",
      "request_fields": [
        {
          "type": "std_msgs/Empty",
          "name": "request",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "std_msgs/Empty",
          "name": "response",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GetCostmap": {
      "description": "Get the costmap",
      "raw": "# Get the costmap\n\n# Specifications for the requested costmap\nnav2_msgs/CostmapMetaData specs\n---\nnav2_msgs/Costmap map\n",
      "request_fields": [
        {
          "type": "nav2_msgs/CostmapMetaData",
          "name": "specs",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "nav2_msgs/Costmap",
          "name": "map",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "LoadMap": {
      "description": "URL of map resource",
      "raw": "# URL of map resource\n# Can be an absolute path to a file: file:///path/to/maps/floor1.yaml\n# Or, relative to a ROS package: package://my_ros_package/maps/floor2.yaml\nstring map_url\n---\n# Result code defintions\nuint8 RESULT_SUCCESS=0\nuint8 RESULT_MAP_DOES_NOT_EXIST=1\nuint8 RESULT_INVALID_MAP_DATA=2\nuint8 RESULT_INVALID_MAP_METADATA=3\nuint8 RESULT_UNDEFINED_FAILURE=255\n\n# Returned map is only valid if result equals RESULT_SUCCESS\nnav_msgs/OccupancyGrid map\nuint8 result\n",
      "request_fields": [
        {
          "type": "string",
          "name": "map_url",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "uint8",
          "name": "RESULT_SUCCESS",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RESULT_MAP_DOES_NOT_EXIST",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RESULT_INVALID_MAP_DATA",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RESULT_INVALID_MAP_METADATA",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RESULT_UNDEFINED_FAILURE",
          "comment": "",
          "default": "255",
          "is_constant": true
        },
        {
          "type": "nav_msgs/OccupancyGrid",
          "name": "map",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "result",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ManageLifecycleNodes": {
      "description": "",
      "raw": "uint8 STARTUP = 0\nuint8 PAUSE = 1\nuint8 RESUME = 2\nuint8 RESET = 3\nuint8 SHUTDOWN = 4\n\nuint8 command\n---\nbool success\n",
      "request_fields": [
        {
          "type": "uint8",
          "name": "STARTUP",
