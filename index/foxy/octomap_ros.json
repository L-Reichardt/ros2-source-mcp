{
  "name": "octomap_ros",
  "version": "0.4.5",
  "description": "octomap_ros provides conversion functions between ROS and OctoMap's native types.\n    This enables a convenvient use of the octomap package in ROS.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://ros.org/wiki/octomap_ros",
      "type": "website"
    },
    {
      "uri": "https://github.com/OctoMap/octomap_ros/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "octomap_ros",
    "url": "https://github.com/OctoMap/octomap_ros.git",
    "branch": "ros2"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake_auto"
    ],
    "test": [
      "ament_cmake_gtest",
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "build_and_runtime": [
      "liboctomap-dev",
      "octomap_msgs",
      "sensor_msgs",
      "tf2"
    ],
    "depended_on_by": [
      "octomap_server"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
