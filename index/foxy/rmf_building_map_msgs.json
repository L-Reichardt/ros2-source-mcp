    "Door": {
      "description": "CONVENTIONS",
      "raw": "string name\n\n# CONVENTIONS\n# ===========\n# single hinge doors:\n#   * hinge is located at (v1_x, v1_y)\n#   * door extends till (v2_x, v2_y)\n#   * motion_range = door swing range in DEGREES\n#   * there are two possible motions: clockwise and anti-clockwise\n#     selected by the motion_direction parameter, which is +1 or -1\n#\n# double hinge doors:\n#   * hinges are located at both (v1_x, v1_y) and (v2_x, v2_y)\n#   * motion range = door swing ranges in DEGREES (assume symmetric)\n#   * same motion-direction selection as single hinge\n#\n# single sliding doors:\n#   * the door slides from (v2_x, v2_y) towards (v1_x, v1_y)\n#   * range of motion is entire distance from v2->v1. No need to specify.\n#\n# double sliding doors:\n#   * door panels slide from the centerpoint of v1<->v2 towards v1 and v2\n#\n# single/double telescoping doors:\n#   * common in elevators; same parameters as sliding doors; they just\n#     open/close faster and take up less space inside the wall.\n\nfloat32 v1_x\nfloat32 v1_y\n\nfloat32 v2_x\nfloat32 v2_y\n\nuint8 door_type\nuint8 DOOR_TYPE_UNDEFINED=0\nuint8 DOOR_TYPE_SINGLE_SLIDING=1\nuint8 DOOR_TYPE_DOUBLE_SLIDING=2\nuint8 DOOR_TYPE_SINGLE_TELESCOPE=3\nuint8 DOOR_TYPE_DOUBLE_TELESCOPE=4\nuint8 DOOR_TYPE_SINGLE_SWING=5\nuint8 DOOR_TYPE_DOUBLE_SWING=6\n\nfloat32 motion_range\nint32 motion_direction\n",
      "fields": [
        {
          "type": "string",
          "name": "name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "v1_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "v1_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "v2_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "v2_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "door_type",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_UNDEFINED",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_SINGLE_SLIDING",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_DOUBLE_SLIDING",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_SINGLE_TELESCOPE",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_DOUBLE_TELESCOPE",
          "comment": "",
          "default": "4",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_SINGLE_SWING",
          "comment": "",
          "default": "5",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "DOOR_TYPE_DOUBLE_SWING",
          "comment": "",
          "default": "6",
          "is_constant": true
        },
        {
          "type": "float32",
          "name": "motion_range",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "motion_direction",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
