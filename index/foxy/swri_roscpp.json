  "messages": {
    "TestTopicServiceRequest": {
      "description": "Test message used only for swri_roscpp unit tests",
      "raw": "# Test message used only for swri_roscpp unit tests\n# Messages for TopicServices would normally be generated by the add_topic_service_files CMake macro\nmarti_common_msgs/ServiceHeader srv_header\nint32 request_value\n",
      "fields": [
        {
          "type": "marti_common_msgs/ServiceHeader",
          "name": "srv_header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "request_value",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "TestTopicServiceResponse": {
      "description": "Test message used only for swri_roscpp unit tests",
      "raw": "# Test message used only for swri_roscpp unit tests\n# Messages for TopicServices would normally be generated by the add_topic_service_files CMake macro\nmarti_common_msgs/ServiceHeader srv_header\nint32 response_value\n",
      "fields": [
        {
          "type": "marti_common_msgs/ServiceHeader",
          "name": "srv_header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "response_value",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "services": {},
  "actions": {}
