{
  "name": "bond",
  "version": "3.0.1",
  "description": "A bond allows two processes, A and B, to know when the other has\n    terminated, either cleanly or by crashing.  The bond remains\n    connected until it is either broken explicitly or until a\n    heartbeat times out.",
  "license": "BSD",
  "build_type": "ament_cmake",
