      "ament_cmake_python",
      "ament_cmake_ros"
    ],
    "test": [
      "ament_cmake_gtest",
      "ament_cmake_pytest"
    ],
    "build_and_runtime": [
      "libopencv-dev",
      "sensor_msgs"
    ],
    "depended_on_by": [
      "camera_calibration",
      "depth_image_proc",
      "depthimage_to_laserscan",
