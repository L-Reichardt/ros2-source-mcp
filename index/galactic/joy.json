{
  "name": "joy",
  "version": "3.0.1",
  "description": "The joy package contains joy_node, a node that interfaces a\n    generic joystick to ROS 2. This node publishes a \"Joy\"\n    message, which contains the current state of each one of the\n    joystick's buttons and axes.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "https://github.com/ros2/joystick_drivers",
      "type": "repository"
    },
    {
      "uri": "https://github.com/ros2/joystick_drivers/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "joystick_drivers",
    "url": "https://github.com/ros-drivers/joystick_drivers.git",
    "branch": "foxy-devel"
  },
  "dependencies": {
