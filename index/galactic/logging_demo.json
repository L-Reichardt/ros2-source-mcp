{
  "name": "logging_demo",
  "version": "0.14.4",
  "description": "Examples for using and configuring loggers.",
  "license": "Apache License 2.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "demos",
    "url": "https://github.com/ros2/demos.git",
    "branch": "galactic"
  },
  "dependencies": {
    "build": [
      "rclcpp",
      "rclcpp_components",
      "rcutils",
      "rosidl_cmake",
      "std_msgs"
    ],
    "buildtool": [
      "ament_cmake",
      "rosidl_default_generators"
    ],
    "runtime": [
      "rclcpp",
      "rclcpp_components",
      "rcutils",
      "rosidl_default_runtime",
      "std_msgs"
    ],
    "test": [
      "ament_cmake_pytest",
      "ament_lint_auto",
      "ament_lint_common",
      "launch",
      "launch_testing",
      "launch_testing_ament_cmake",
      "launch_testing_ros",
      "rmw_implementation_cmake"
    ],
    "depended_on_by": [
      "desktop"
    ]
  },
  "messages": {},
  "services": {
    "ConfigLogger": {
      "description": "",
      "raw": "string logger_name\nstring level\n---\nbool success\n",
      "request_fields": [
        {
          "type": "string",
          "name": "logger_name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "level",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "actions": {}
}
