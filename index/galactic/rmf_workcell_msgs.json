    "WorkcellRequest": {
      "description": "This is a template message for all types of workcells to build off from,",
      "raw": "# This is a template message for all types of workcells to build off from,\n# which allows generic workcell libraries to have access to common message\n# fields.\n\nbuiltin_interfaces/Time time\n\n# A unique ID for this request\nstring request_guid\n\n# The unique ID of the workcell that this request is aimed at\nstring target_guid\n\n# below are custom workcell-type message fields\n",
      "fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "time",
          "comment": "",
          "default": null,
          "is_constant": false
