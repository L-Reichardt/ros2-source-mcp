{
  "name": "rosapi",
  "version": "1.3.1",
  "description": "Provides service calls for getting ros meta-information, like list of\n    topics, services, params, etc.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://ros.org/wiki/rosapi",
      "type": "website"
    },
    {
      "uri": "https://github.com/RobotWebTools/rosbridge_suite/issues",
      "type": "bugtracker"
    },
    {
      "uri": "https://github.com/RobotWebTools/rosbridge_suite",
      "type": "repository"
    }
  ],
  "repo": {
    "name": "rosbridge_suite",
