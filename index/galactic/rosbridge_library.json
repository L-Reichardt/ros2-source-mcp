{
  "name": "rosbridge_library",
  "version": "1.3.1",
  "description": "The core rosbridge package, responsible for interpreting JSON andperforming\n    the appropriate ROS action, like subscribe, publish, call service, and\n    interact with params.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://ros.org/wiki/rosbridge_library",
      "type": "website"
    },
    {
      "uri": "https://github.com/RobotWebTools/rosbridge_suite/issues",
      "type": "bugtracker"
    },
    {
      "uri": "https://github.com/RobotWebTools/rosbridge_suite",
      "type": "repository"
    }
  ],
  "repo": {
    "name": "rosbridge_suite",
    "url": "https://github.com/RobotWebTools/rosbridge_suite.git",
