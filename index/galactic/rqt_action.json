{
  "name": "rqt_action",
  "version": "2.0.1",
  "description": "rqt_action provides a feature to introspect all available ROS\n  action types. By utilizing rqt_msg, the output format is\n  unified with it and rqt_srv. Note that the actions shown on this plugin\n  is the ones that are stored on your machine, not on the ROS core your rqt\n  instance connects to.",
  "license": "BSD",
  "build_type": "ament_python",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://wiki.ros.org/rqt_action",
      "type": "website"
    },
    {
      "uri": "https://github.com/ros-visualization/rqt_action",
      "type": "repository"
    },
    {
      "uri": "https://github.com/ros-visualization/rqt_action/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "rqt_action",
    "url": "https://github.com/ros-visualization/rqt_action.git",
    "branch": "galactic"
  },
  "dependencies": {
    "runtime": [
      "rclpy",
      "rqt_msg",
      "python_qt_binding",
      "rqt_gui",
      "rqt_gui_py",
      "rqt_py_common"
    ],
    "depended_on_by": [
      "rqt_common_plugins"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
