{
  "name": "tile_map",
  "version": "2.2.0",
  "description": "Tile map provides a slippy map style interface for visualizing \n     OpenStreetMap and GoogleMap tiles.  A mapviz visualization plug-in is also\n     implemented",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "https://github.com/swri-robotics/mapviz",
      "type": "website"
    }
  ],
  "repo": {
    "name": "mapviz",
    "url": "https://github.com/swri-robotics/mapviz.git",
    "branch": "ros2-devel"
  },
  "dependencies": {
    "build": [
      "libjsoncpp-dev",
      "libqt5-opengl-dev"
    ],
    "buildtool": [
      "ament_cmake",
      "qt5-qmake"
    ],
    "runtime": [
      "libjsoncpp",
      "libqt5-opengl"
    ],
    "build_and_runtime": [
      "libqt5-core",
      "libglew-dev",
      "mapviz",
      "pluginlib",
      "rclcpp",
      "swri_math_util",
      "swri_transform_util",
      "tf2",
      "yaml-cpp"
    ],
    "depended_on_by": []
  },
  "messages": {},
  "services": {},
  "actions": {}
}
