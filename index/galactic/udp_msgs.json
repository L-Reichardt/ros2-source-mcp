{
  "name": "udp_msgs",
  "version": "0.0.3",
  "description": "ROS2 udp_msgs package",
  "license": "MIT",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "udp_msgs",
    "url": "https://github.com/flynneva/udp_msgs.git",
    "branch": "main"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake",
      "rosidl_default_generators"
    ],
    "runtime": [
      "rosidl_default_runtime"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "build_and_runtime": [
      "std_msgs"
    ],
    "depended_on_by": [
      "io_context",
      "udp_driver"
    ]
  },
  "messages": {
    "UdpPacket": {
      "description": "",
      "raw": "std_msgs/Header header\nstring address\nuint16 src_port\nuint8[] data\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "address",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "src_port",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8[]",
          "name": "data",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "services": {
    "UdpSend": {
      "description": "",
      "raw": "string local_address\nuint16 local_port\nstring remote_address\nuint16 remote_port\nuint8[] data\n---\nbool sent\n",
      "request_fields": [
        {
          "type": "string",
          "name": "local_address",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "local_port",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "remote_address",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "remote_port",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8[]",
          "name": "data",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "sent",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "UdpSocket": {
      "description": "",
      "raw": "string local_address\nuint16 local_port\nstring remote_address\nuint16 remote_port\nbool is_broadcast\n---\nbool socket_created\n",
      "request_fields": [
        {
          "type": "string",
          "name": "local_address",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "local_port",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "remote_address",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "remote_port",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "is_broadcast",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "socket_created",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "actions": {}
}
