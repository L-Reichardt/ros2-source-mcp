{
  "name": "urdf",
  "version": "2.5.2",
  "description": "This package contains a C++ parser for the Unified Robot Description\n    Format (URDF), which is an XML format for representing a robot model.\n    The code API of the parser has been through our review process and will remain\n    backwards compatible in future releases.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "https://github.com/ros2/urdf",
      "type": "repository"
    },
    {
      "uri": "https://github.com/ros2/urdf/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "urdf",
    "url": "https://github.com/ros2/urdf.git",
    "branch": "galactic"
  },
  "dependencies": {
    "build": [
      "pluginlib",
      "tinyxml2_vendor",
      "urdfdom",
      "urdf_parser_plugin",
      "urdfdom_headers"
    ],
    "build_export": [
      "pluginlib",
      "urdf_parser_plugin",
      "urdfdom",
      "urdfdom_headers"
    ],
    "buildtool": [
      "ament_cmake_ros"
    ],
    "runtime": [
      "pluginlib",
      "tinyxml2_vendor",
      "urdfdom",
      "urdfdom_headers"
    ],
    "test": [
      "ament_cmake_google_benchmark",
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "depended_on_by": [
      "ign_rviz_plugins",
      "kdl_parser",
      "kdl_parser",
      "mavros_extras",
      "moveit_core",
      "moveit_setup_assistant",
      "robot_state_publisher",
      "robot_state_publisher",
      "ros_base",
      "rviz_common",
      "rviz_default_plugins",
      "sdformat_urdf",
      "srdfdom",
      "srdfdom",
      "turtlebot3_description",
      "turtlebot4_description",
      "ur_bringup",
      "ur_description",
      "ur_moveit_config",
      "velodyne_description"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
