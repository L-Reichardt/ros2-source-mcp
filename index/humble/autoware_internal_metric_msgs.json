{
  "name": "autoware_internal_metric_msgs",
  "version": "1.12.1",
  "description": "The autoware_internal_metric_msgs package",
  "license": "Apache License 2.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "autoware_internal_msgs",
    "url": "https://github.com/autowarefoundation/autoware_internal_msgs.git",
    "branch": "main"
  },
  "dependencies": {
    "build": [
      "rosidl_default_generators"
    ],
    "buildtool": [
      "ament_cmake_auto"
    ],
    "runtime": [
      "rosidl_default_runtime"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "build_and_runtime": [
      "builtin_interfaces"
    ],
    "depended_on_by": [
      "autoware_internal_msgs"
    ]
  },
  "messages": {
    "Metric": {
      "description": "name of the metric",
      "raw": "# name of the metric\nstring name\n\n# unit (or type) of the metric\n# you can leave it empty or assign any identifier to the unit, such as \"milliseconds\", \"m/s\", \"IoU\", \"battery percentage\", etc.\nstring unit\n\n# value of the metric\nstring value\n",
      "fields": [
        {
          "type": "string",
          "name": "name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "unit",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "value",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "MetricArray": {
      "description": "time stamp",
      "raw": "# time stamp\nbuiltin_interfaces/Time stamp\n\n# metrics list\nMetric[] metric_array\n",
      "fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "stamp",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "Metric[]",
          "name": "metric_array",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "services": {},
  "actions": {}
}
