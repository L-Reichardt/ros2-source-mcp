    "ConcatenatedPointCloudInfo": {
      "description": "This message holds information about a concatenated point cloud that combines multiple source",
      "raw": "# This message holds information about a concatenated point cloud that combines multiple source\n# point clouds, including the overall point cloud structure and metadata for each source segment.\n\n# Available matching strategies for source point clouds concatenation\nuint8 STRATEGY_NAIVE = 0     # Assigns the oldest stamp of the sensor that was concatenated\nuint8 STRATEGY_ADVANCED = 1  # Assigns the oldest stamp of the sensor that was concatenated\n\n# The concatenated point cloud header, where timestamp assignment depends on matching strategy\nstd_msgs/Header header\n\nbool concatenation_success                       # Whether concatenation was successful\nuint8 matching_strategy                          # Strategy used for concatenation\n\n# Raw data of concatenation config, relevant to matching_strategy field.\nuint8[] matching_strategy_config\n\nSourcePointCloudInfo[] source_info               # Meta information of input point clouds\n",
      "fields": [
        {
          "type": "uint8",
          "name": "STRATEGY_NAIVE",
          "comment": "Assigns the oldest stamp of the sensor that was concatenated",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "STRATEGY_ADVANCED",
          "comment": "Assigns the oldest stamp of the sensor that was concatenated",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "concatenation_success",
          "comment": "Whether concatenation was successful",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "matching_strategy",
          "comment": "Strategy used for concatenation",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8[]",
          "name": "matching_strategy_config",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "SourcePointCloudInfo[]",
          "name": "source_info",
          "comment": "Meta information of input point clouds",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GnssInsOrientation": {
      "description": "GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message",
      "raw": "# GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message\n#\n# Represents a 3D orientation in a global coordinate system.\n#\n# ROS uses ENU axes convention (East, North, Up) corresponds to (x, y, z).\n\n# Quaternion representation of the orientation.\ngeometry_msgs/Quaternion orientation\n\n# Root mean square error of the rotation [rad]\n# (x, y, z) axes corresponding to (roll, pitch, yaw)\nfloat32 rmse_rotation_x\nfloat32 rmse_rotation_y\nfloat32 rmse_rotation_z\n",
      "fields": [
        {
          "type": "geometry_msgs/Quaternion",
          "name": "orientation",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "rmse_rotation_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "rmse_rotation_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "rmse_rotation_z",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GnssInsOrientationStamped": {
      "description": "GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message",
      "raw": "# GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message\n#\n# Represents a 3D orientation in a global coordinate system with coordinate frame and timestamp.\n\n# Timestamp this reading was received by the INS sensor\n# Frame is expected to be of the INS device\nstd_msgs/Header header\n\nGnssInsOrientation orientation\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "GnssInsOrientation",
          "name": "orientation",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
