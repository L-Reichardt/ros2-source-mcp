    "SourcePointCloudInfo": {
      "description": "This message holds metadata information about a source point cloud segment",
      "raw": "# This message holds metadata information about a source point cloud segment\n# within a concatenated point cloud, including its spatial boundaries and structural properties.\n\n# Available status codes for source point cloud\nuint8 STATUS_OK = 0       # Cloud received (may have 0 or more points)\nuint8 STATUS_TIMEOUT = 1  # Cloud not received due to timeout\nuint8 STATUS_INVALID = 2  # Cloud arrived but was malformed/corrupt\n\n# Time of sensor data acquisition, and the coordinate frame ID (for 3d points).\nstd_msgs/Header header\n\nstring topic              # Source topic\nuint8 status              # Status of the source point cloud\n\n# The starting index (inclusive) of the point cloud segment within the concatenated point cloud\nuint32 idx_begin\n\n# The length of the point cloud segment in the concatenated point cloud\nuint32 length\n",
      "fields": [
        {
          "type": "uint8",
          "name": "STATUS_OK",
          "comment": "Cloud received (may have 0 or more points)",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "STATUS_TIMEOUT",
          "comment": "Cloud not received due to timeout",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "STATUS_INVALID",
          "comment": "Cloud arrived but was malformed/corrupt",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "topic",
          "comment": "Source topic",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "status",
          "comment": "Status of the source point cloud",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "idx_begin",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "length",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
