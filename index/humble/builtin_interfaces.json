  "messages": {
    "Duration": {
      "description": "Duration defines a period between two time points.",
      "raw": "# Duration defines a period between two time points.\n# Messages of this datatype are of ROS Time following this design:\n# https://design.ros2.org/articles/clock_and_time.html\n\n# The seconds component, valid over all int32 values.\nint32 sec\n\n# The nanoseconds component, valid in the range [0, 1e9), to be added to the seconds component.\n# e.g.\n# The duration -1.7 seconds is represented as {sec: -2, nanosec: 3e8}\n# The duration 1.7 seconds is represented as {sec: 1, nanosec: 7e8}\nuint32 nanosec\n",
      "fields": [
        {
          "type": "int32",
          "name": "sec",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "nanosec",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Time": {
