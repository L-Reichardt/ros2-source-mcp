    "Feedback": {
      "description": "This message represents high-frequency feedback from the MCU,",
      "raw": "# This message represents high-frequency feedback from the MCU,\n# as necessary to support closed-loop control and thermal monitoring.\n# Default publish frequency is 50Hz.\n\nstd_msgs/Header header\n\nDriveFeedback[2] drivers\n\n# Commanded control mode, use the TYPE_ constants from jackal_msgs/Drive.\nint8 commanded_mode\n\n# Actual control mode. This may differ from the commanded in cases where\n# the motor enable is off, the motors are in over-current, etc.\nint8 actual_mode\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "DriveFeedback[2]",
          "name": "drivers",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8",
          "name": "commanded_mode",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8",
          "name": "actual_mode",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
