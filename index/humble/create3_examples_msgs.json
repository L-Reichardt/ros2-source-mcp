{
  "name": "create3_examples_msgs",
  "version": "0.0.5",
  "description": "Package containing action, message and service definitions used by the iRobot(R) Create(R) 3 examples",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "create3_examples",
    "url": "https://github.com/iRobotEducation/create3_examples.git",
    "branch": "humble"
  },
  "dependencies": {
    "build": [
      "action_msgs",
      "builtin_interfaces"
    ],
    "buildtool": [
      "ament_cmake",
      "rosidl_default_generators"
    ],
    "runtime": [
      "action_msgs",
      "builtin_interfaces",
      "rosidl_default_runtime"
    ],
    "test": [
      "ament_lint_common"
    ],
    "depended_on_by": [
      "create3_coverage"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {
    "Coverage": {
      "description": "Request",
      "raw": "# Request\n\n# The robot will explore the environment for `explore_duration` time.\n# After that, it will try to dock as soon as it sees the docking station.\n# The `max_runtime` duration defines when the behavior should end regardless of whether\n# the dock has been found or not. \n\nbuiltin_interfaces/Duration explore_duration\nbuiltin_interfaces/Duration max_runtime\n---\n# Result\nbool success\nbool is_docked\nbuiltin_interfaces/Duration duration\n---\n# Feedback\n\nint32 DOCK = 0\nint32 DRIVE_STRAIGHT = 1\nint32 ROTATE = 2\nint32 SPIRAL = 3\nint32 UNDOCK = 4\n\nint32 current_behavior\n",
      "goal_fields": [
        {
          "type": "builtin_interfaces/Duration",
          "name": "explore_duration",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "builtin_interfaces/Duration",
          "name": "max_runtime",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "result_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "is_docked",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "builtin_interfaces/Duration",
          "name": "duration",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "feedback_fields": [
        {
          "type": "int32",
          "name": "DOCK",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "DRIVE_STRAIGHT",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "ROTATE",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "SPIRAL",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "UNDOCK",
          "comment": "",
          "default": "4",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "current_behavior",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  }
}
