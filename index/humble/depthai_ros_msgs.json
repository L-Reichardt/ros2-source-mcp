        {
          "type": "uint8",
          "name": "POINTS",
          "comment": "",
          "default": "4",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "TEXT",
          "comment": "",
          "default": "5",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "ADD",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "REMOVE",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "ns",
          "comment": "namespace, used with id to form a unique id",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "id",
          "comment": "unique id within the namespace",
          "default": null,
          "is_constant": false
