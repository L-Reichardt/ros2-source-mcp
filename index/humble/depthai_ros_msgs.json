    "ImageMarker": {
      "description": "",
      "raw": "uint8 CIRCLE=0\nuint8 LINE_STRIP=1\nuint8 LINE_LIST=2\nuint8 POLYGON=3\nuint8 POINTS=4\nuint8 TEXT=5\n\nuint8 ADD=0\nuint8 REMOVE=1\n\nHeader header\nstring ns # namespace, used with id to form a unique id\nint32 id           # unique id within the namespace\nint32 type         # CIRCLE/LINE_STRIP/etc.\nint32 action       # ADD/REMOVE\ngeometry_msgs/Point position # 2D, in pixel-coords\nfloat32 scale   # the diameter for a circle, etc.\nstd_msgs/ColorRGBA outline_color\nuint8 filled # whether to fill in the shape with color\nstd_msgs/ColorRGBA fill_color # color [0.0-1.0]\nduration lifetime       # How long the object should last before being automatically deleted.  0 means forever\n\n\ngeometry_msgs/Point[] points # used for LINE_STRIP/LINE_LIST/POINTS/etc., 2D in pixel coords\nstd_msgs/ColorRGBA[] outline_colors # a color for each line, point, etc.\n\nstd_msgs/String text\n",
      "fields": [
        {
          "type": "uint8",
          "name": "CIRCLE",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "LINE_STRIP",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "LINE_LIST",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "POLYGON",
