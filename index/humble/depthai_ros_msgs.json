        {
          "type": "geometry_msgs/Point",
          "name": "position",
          "comment": "2D, in pixel-coords",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "scale",
          "comment": "the diameter for a circle, etc.",
          "default": null,
          "is_constant": false
        },
        {
          "type": "std_msgs/ColorRGBA",
          "name": "outline_color",
          "comment": "",
          "default": null,
          "is_constant": false
