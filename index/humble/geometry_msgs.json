    "AccelStamped": {
      "description": "An accel with reference coordinate frame and timestamp",
      "raw": "# An accel with reference coordinate frame and timestamp\nstd_msgs/Header header\nAccel accel\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
