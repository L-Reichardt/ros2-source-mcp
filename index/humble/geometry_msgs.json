  "messages": {
    "Accel": {
      "description": "This expresses acceleration in free space broken into its linear and angular parts.",
      "raw": "# This expresses acceleration in free space broken into its linear and angular parts.\nVector3  linear\nVector3  angular\n",
      "fields": [
        {
          "type": "Vector3",
          "name": "linear",
