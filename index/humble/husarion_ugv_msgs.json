    "ChargingStatus": {
      "description": "This message defines the battery charging process status",
      "raw": "# This message defines the battery charging process status\n\n# Charger types\nuint8 UNKNOWN = 0\nuint8 WIRED = 1\nuint8 WIRELESS = 2\n\nstd_msgs/Header header\nbool charging               # True if battery is being charged\nfloat32 current             # Power supply total current (A)\nfloat32 current_battery_1   # Power supply current (A) for battery 1\nfloat32 current_battery_2   # Power supply current (A) for battery 2 (NaN for single battery configuration)\nuint8 charger_type          # Determines the type of charger connection\n",
      "fields": [
        {
          "type": "uint8",
          "name": "UNKNOWN",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "WIRED",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "WIRELESS",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "charging",
          "comment": "True if battery is being charged",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "current",
          "comment": "Power supply total current (A)",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "current_battery_1",
          "comment": "Power supply current (A) for battery 1",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "current_battery_2",
          "comment": "Power supply current (A) for battery 2 (NaN for single battery configuration)",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "charger_type",
          "comment": "Determines the type of charger connection",
          "default": null,
          "is_constant": false
        }
      ]
    },
