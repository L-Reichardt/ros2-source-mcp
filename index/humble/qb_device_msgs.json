  "messages": {
    "ConnectionState": {
      "description": "Device-independent connection state message",
      "raw": "# Device-independent connection state message\n\nqb_device_msgs/DeviceConnectionInfo[] devices",
      "fields": [
        {
          "type": "qb_device_msgs/DeviceConnectionInfo[]",
          "name": "devices",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "DeviceConnectionInfo": {
      "description": "Device-independent message that constains:",
      "raw": "# Device-independent message that constains: \n\nint32 id           # device id;\nbool is_active     # motor activation status;\nstring port        # serial port",
      "fields": [
        {
          "type": "int32",
          "name": "id",
          "comment": "device id;",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "is_active",
          "comment": "motor activation status;",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "port",
          "comment": "serial port",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Info": {
      "description": "Standard device-independent info message",
      "raw": "# Standard device-independent info message\n\nint32 id\nstring serial_port\nint32 max_repeats\nbool get_positions\nbool get_currents\nbool get_distinct_packages\nbool set_commands\nbool set_commands_async\nint32[] position_limits\nuint8[] encoder_resolutions",
      "fields": [
        {
          "type": "int32",
          "name": "id",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "serial_port",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "max_repeats",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "get_positions",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "get_currents",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "get_distinct_packages",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "set_commands",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "set_commands_async",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32[]",
          "name": "position_limits",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8[]",
          "name": "encoder_resolutions",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ResourceData": {
      "description": "Device-independent resource data message",
      "raw": "# Device-independent resource data message\n\nstring name\nfloat64 position\nfloat64 velocity\nfloat64 effort\nfloat64 command",
      "fields": [
        {
          "type": "string",
          "name": "name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "position",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "velocity",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "effort",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "command",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "State": {
      "description": "State message valid for either qbhand or qbmove",
      "raw": "# State message valid for either qbhand or qbmove\n\n# either qbhand or qbmove:\n#  - motors: position, command in [ticks], velocity in [ticks/s], effort in [mA]\nqb_device_msgs/ResourceData[] actuators\n\n# qbhand:\n#  - closure: position, command in [0,1], velocity in [percent/s],  effort in [A].\n# qbmove:\n#  - shaft: position, command in [radians], velocity in [radians/s], effort in [A];\n#  - preset: position, command in [0,1], velocity in [percent/s], effort is not used.\nqb_device_msgs/ResourceData[] joints\n\n# Reliability of the retrieved measurements\nbool is_reliable\nint32 consecutive_failures",
      "fields": [
        {
          "type": "qb_device_msgs/ResourceData[]",
          "name": "actuators",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "qb_device_msgs/ResourceData[]",
          "name": "joints",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "is_reliable",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "consecutive_failures",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "StateStamped": {
      "description": "State message with stamped info valid for either qbhand or qbmove",
      "raw": "# State message with stamped info valid for either qbhand or qbmove\n\nstd_msgs/Header header\n\nqb_device_msgs/Info device_info\n\nqb_device_msgs/State device_data",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "qb_device_msgs/Info",
          "name": "device_info",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "qb_device_msgs/State",
          "name": "device_data",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
