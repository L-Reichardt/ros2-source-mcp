{
  "name": "qb_device_msgs",
  "version": "4.1.3",
  "description": "This package contains the device-independent custom ROS messages for qbrobotics® devices.",
  "license": "BSD 3-Clause",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "https://bitbucket.org/qbrobotics/qbdevice-ros/issues",
      "type": "bugtracker"
    },
    {
      "uri": "https://bitbucket.org/qbrobotics/qbdevice-ros",
      "type": "repository"
    },
    {
      "uri": "http://wiki.ros.org/qb_device_msgs",
      "type": "website"
    }
  ],
  "repo": {
    "name": "qb_device",
    "url": "https://bitbucket.org/qbrobotics/qbdevice-ros.git",
    "branch": "production-humble"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake",
      "rosidl_default_generators"
    ],
    "runtime": [
      "rosidl_default_runtime"
    ],
