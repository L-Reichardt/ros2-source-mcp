  "actions": {
    "BasicAction": {
      "description": "",
      "raw": "string goal\n---\nstring result\n---\nstring feedback\n",
      "goal_fields": [
        {
          "type": "string",
          "name": "goal",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "result_fields": [
        {
          "type": "string",
          "name": "result",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "feedback_fields": [
        {
          "type": "string",
          "name": "feedback",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  }
