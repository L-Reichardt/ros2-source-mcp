      "description": "CONSTANTS",
      "raw": "########################################\n# CONSTANTS\n########################################\n# uint8 OFF           = 0\n# uint8 ON            = 1\n# uint8 LOW_BATTERY   = 2\n# uint8 ERROR         = 3\n# uint8 BUTTON1       = 4\n# uint8 BUTTON2       = 5\n\nuint8 value\n---\nbool success\nstring message\n",
