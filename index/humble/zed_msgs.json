    "GnssFusionStatus": {
      "description": "GNSS_FUSION_STATUS",
      "raw": "# GNSS_FUSION_STATUS\n# Represents the current state of GNSS fusion for global localization.\n# OK - The GNSS fusion module is calibrated and working successfully.\n# OFF - The GNSS fusion module is not enabled.\n# CALIBRATION_IN_PROGRESS - Calibration of the GNSS/VIO fusion module is in progress.\n# RECALIBRATION_IN_PROGRESS- Re-alignment of GNSS/VIO data is in progress, leading to potentially inaccurate global position.\nuint8 OK = 0\nuint8 OFF = 1\nuint8 CALIBRATION_IN_PROGRESS = 2\nuint8 RECALIBRATION_IN_PROGRESS = 3\n\nuint8 gnss_fusion_status",
      "fields": [
        {
          "type": "uint8",
          "name": "OK",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "OFF",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CALIBRATION_IN_PROGRESS",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "RECALIBRATION_IN_PROGRESS",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "gnss_fusion_status",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
