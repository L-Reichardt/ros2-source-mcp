{
  "name": "ffmpeg_image_transport",
  "version": "1.2.1",
  "description": "ffmpeg_image_transport provides a plugin to image_transport for\n    transparently sending an image stream encoded with ffmpeg.",
  "license": "Apache-2",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://www.ros.org/wiki/image_transport_plugins",
      "type": "website"
    }
  ],
  "repo": {
    "name": "ffmpeg_image_transport",
    "url": "https://github.com/ros-misc-utilities/ffmpeg_image_transport.git",
    "branch": "iron"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake",
      "ament_cmake_ros",
      "ament_cmake_clang_format",
      "pkg-config",
      "ros_environment"
    ],
    "test": [
      "ament_lint_common",
      "ament_lint_auto"
    ],
    "build_and_runtime": [
      "cv_bridge",
      "image_transport",
      "libogg",
      "libopencv-imgproc-dev",
      "pluginlib",
      "rclcpp",
      "rcutils",
      "sensor_msgs",
      "std_msgs",
      "ffmpeg_image_transport_msgs",
      "ffmpeg",
      "libavdevice-dev"
    ],
    "depended_on_by": [
      "ffmpeg_image_transport_tools"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
