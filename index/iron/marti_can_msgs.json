          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "id",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "msg_type",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "MSGTYPE_STANDARD",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "MSGTYPE_RTR",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "MSGTYPE_EXTENDED",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "MSGTYPE_STATUS",
          "comment": "",
          "default": "128",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "data_length",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8[8]",
