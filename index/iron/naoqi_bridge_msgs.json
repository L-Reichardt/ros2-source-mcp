    "RobotInfo": {
      "description": "info here is inspired by http://doc.aldebaran.com/2-1/naoqi/motion/tools-general-api.html?highlight=getrobotconfig#AL...",
      "raw": "# info here is inspired by http://doc.aldebaran.com/2-1/naoqi/motion/tools-general-api.html?highlight=getrobotconfig#ALMotionProxy::getRobotConfig\n\n# enums describing the robot type\nuint8 NAO=0\nuint8 ROMEO=1\nuint8 PEPPER=2\n\n# one of NAO, ROMEO, PEPPER\nuint8 type\n\n# \"Model Type\"   : \"naoH25\", \"naoH21\", \"naoT14\" or \"naoT2\".\nstring model\n# \"Head Version\" : \"VERSION_32\" or \"VERSION_33\" or \"VERSION_40\".\nstring head_version\n# \"Body Version\" : \"VERSION_32\" or \"VERSION_33\" or \"VERSION_40\".\nstring body_version\n# \"Arm Version\"  : \"VERSION_32\" or \"VERSION_33\" or \"VERSION_40\".\nstring arm_version\n\n# \"Laser\"        : True or False.\nbool has_laser\n# \"Extended Arms\": True or False.\nbool has_extended_arms\n\n# Number of Legs : 0 or 2\nint32 number_of_legs\n# Number of Arms : 0 or 2\nint32 number_of_arms\n# Number of Hands: 0 or 2\nint32 number_of_hands\n",
      "fields": [
        {
          "type": "uint8",
          "name": "NAO",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "ROMEO",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "PEPPER",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "type",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "model",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "head_version",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "body_version",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "arm_version",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "has_laser",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
