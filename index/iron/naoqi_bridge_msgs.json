    "AudioBuffer": {
      "description": "timestanp the audio buffer",
      "raw": "# timestanp the audio buffer\nstd_msgs/Header header\n# current frequency of the audio interface\nuint16 frequency\n# channel order properties :\nuint8 CHANNEL_FRONT_LEFT=0\nuint8 CHANNEL_FRONT_CENTER=1\nuint8 CHANNEL_FRONT_RIGHT=2\nuint8 CHANNEL_REAR_LEFT=3\nuint8 CHANNEL_REAR_CENTER=4\nuint8 CHANNEL_REAR_RIGHT=5\nuint8 CHANNEL_SURROUND_LEFT=6\nuint8 CHANNEL_SURROUND_RIGHT=7\nuint8 CHANNEL_SUBWOOFER=8\nuint8 CHANNEL_LFE=9\n# channel order of the current buffer\nuint8[] channel_map\n# interlaced data of the audio buffer\nint16[] data",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "frequency",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "CHANNEL_FRONT_LEFT",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_FRONT_CENTER",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_FRONT_RIGHT",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_REAR_LEFT",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_REAR_CENTER",
          "comment": "",
          "default": "4",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_REAR_RIGHT",
          "comment": "",
          "default": "5",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_SURROUND_LEFT",
          "comment": "",
          "default": "6",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_SURROUND_RIGHT",
          "comment": "",
          "default": "7",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_SUBWOOFER",
          "comment": "",
          "default": "8",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CHANNEL_LFE",
          "comment": "",
          "default": "9",
          "is_constant": true
        },
        {
          "type": "uint8[]",
          "name": "channel_map",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int16[]",
          "name": "data",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
