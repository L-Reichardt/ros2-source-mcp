          "is_constant": false
        },
        {
          "type": "int32",
          "name": "number_of_legs",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "number_of_arms",
          "comment": "",
          "default": null,
          "is_constant": false
