{
  "name": "resource_retriever",
  "version": "3.2.3",
  "description": "This package retrieves data from url-format files such as http://,\n   ftp://, package:// file://, etc., and loads the data into memory.\n   The package:// url for ros packages is translated into a local\n   file:// url.  The resourse retriever was initially designed to load\n   mesh files into memory, but it can be used for any type of\n   data. The resource retriever is based on the the libcurl library.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://ros.org/wiki/resource_retriever",
      "type": "website"
    },
    {
      "uri": "https://github.com/ros/robot_model",
      "type": "repository"
    },
    {
      "uri": "https://github.com/ros/robot_model/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "resource_retriever",
    "url": "https://github.com/ros/resource_retriever.git",
    "branch": "iron"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake_ros"
    ],
    "test": [
      "ament_cmake_gtest",
      "ament_cmake_pytest",
      "ament_lint_auto",
      "ament_lint_common",
      "python3-pytest",
      "python_cmake_module"
    ],
    "build_and_runtime": [
      "ament_index_cpp",
      "ament_index_python",
      "libcurl_vendor"
    ],
    "depended_on_by": [
      "foxglove_bridge",
      "geometric_shapes",
      "nav2_rviz_plugins",
      "rmf_visualization_rviz2_plugins",
      "rviz_common",
      "rviz_default_plugins",
      "rviz_rendering",
      "rviz_rendering",
      "rviz_rendering_tests"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
