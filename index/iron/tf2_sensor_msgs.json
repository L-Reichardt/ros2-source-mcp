{
  "name": "tf2_sensor_msgs",
  "version": "0.31.8",
  "description": "Small lib to transform sensor_msgs with tf. Most notably, PointCloud2",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://www.ros.org/wiki/tf2_ros",
      "type": "website"
    }
