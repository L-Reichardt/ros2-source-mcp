      "fields": [
        {
          "type": "uint8",
          "name": "version_h",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "version_l",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "bms_status",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "soc",
          "comment": "SOC 0-100%",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "current",
          "comment": "mA",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "cycle",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8[2]",
          "name": "bq_ntc",
          "comment": "x1 degrees centigrade",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8[2]",
          "name": "mcu_ntc",
          "comment": "x1 degrees centigrade",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16[10]",
          "name": "cell_vol",
          "comment": "cell voltage mV",
          "default": null,
          "is_constant": false
        }
