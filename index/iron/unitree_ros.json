{
  "name": "unitree_ros",
  "version": "1.1.1",
  "description": "Unitree ros package",
  "license": "GPL-3.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "unitree_ros",
    "url": "https://github.com/snt-arg/unitree_ros.git",
    "branch": "main"
  },
  "dependencies": {
    "build": [
      "rosidl_default_generators",
      "boost"
    ],
