  "actions": {
    "SetMode": {
      "description": "This action is for setting the robot into a desired mode (e.g. RUNNING) and safety mode into a",
      "raw": "# This action is for setting the robot into a desired mode (e.g. RUNNING) and safety mode into a\n# non-critical state (e.g. NORMAL or REDUCED), for example after a safety incident happened.\n\n# goal\nint8 target_robot_mode\n\n# Stop program execution before restoring the target mode. Can be used together with 'play_program'.\nbool stop_program\n\n# Play the currently loaded program after target mode is reached.#\n# NOTE: Requesting mode RUNNING in combination with this will make the robot continue the motion it\n# was doing before. This might probably lead into the same problem (protective stop, EM-Stop due to\n# faulty motion, etc.) If you want to be safe, set the 'stop_program' flag below and manually play\n# the program after robot state is returned to normal.\n# This flag will only be used when requesting mode RUNNING\nbool play_program\n\n---\n# result\nbool success\nstring message\n---\n# feedback\nint8 current_robot_mode\nint8 current_safety_mode\n",
      "goal_fields": [
        {
          "type": "int8",
          "name": "target_robot_mode",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "stop_program",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "play_program",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "result_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "message",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "feedback_fields": [
        {
          "type": "int8",
          "name": "current_robot_mode",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8",
          "name": "current_safety_mode",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
