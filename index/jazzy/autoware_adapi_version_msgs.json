{
  "name": "autoware_adapi_version_msgs",
  "version": "1.9.0",
  "description": "The Autoware AD API version interfaces",
  "license": "Apache License 2.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "autoware_adapi_msgs",
    "url": "https://github.com/autowarefoundation/autoware_adapi_msgs.git",
    "branch": "main"
  },
  "dependencies": {
    "build": [
      "rosidl_default_generators"
    ],
    "buildtool": [
      "ament_cmake_auto"
    ],
    "runtime": [
      "rosidl_default_runtime"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "depended_on_by": []
  },
  "messages": {},
  "services": {
    "InterfaceVersion": {
      "description": "",
      "raw": "---\nuint16 major\nuint16 minor\nuint16 patch\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "uint16",
          "name": "major",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "minor",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "patch",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "actions": {}
}
