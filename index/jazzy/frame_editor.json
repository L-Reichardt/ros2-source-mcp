  "messages": {},
  "services": {
    "AlignFrame": {
      "description": "modes ##",
      "raw": "string name\nstring source_name\n\nint32 mode\n\n## modes ##\n##\nint32 MODE_NONE = 0\nint32 MODE_X = 1\nint32 MODE_Y = 2\nint32 MODE_Z = 4\nint32 MODE_A = 8\nint32 MODE_B = 16\nint32 MODE_C = 32\n\n## common binary combinations\nint32 MODE_POSITION = 7\nint32 MODE_ORIENTATION = 56\nint32 MODE_POSE = 63\n\n---\nint32 error_code",
      "request_fields": [
        {
          "type": "string",
          "name": "name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "source_name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "mode",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "MODE_NONE",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_X",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_Y",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_Z",
          "comment": "",
          "default": "4",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_A",
          "comment": "",
          "default": "8",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_B",
          "comment": "",
          "default": "16",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_C",
          "comment": "",
          "default": "32",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_POSITION",
          "comment": "",
          "default": "7",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_ORIENTATION",
          "comment": "",
          "default": "56",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "MODE_POSE",
          "comment": "",
          "default": "63",
          "is_constant": true
        }
      ],
      "response_fields": [
        {
          "type": "int32",
          "name": "error_code",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
