  "deprecated": null,
  "urls": [
    {
      "uri": "http://www.ipa.fraunhofer.de/",
      "type": "website"
    }
  ],
  "repo": {
    "name": "frame_editor",
    "url": "https://github.com/ipa320/rqt_frame_editor_plugin.git",
    "branch": "jazzy-devel"
