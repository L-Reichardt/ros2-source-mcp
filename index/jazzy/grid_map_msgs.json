{
  "name": "grid_map_msgs",
  "version": "2.2.2",
  "description": "Definition of the multi-layered grid map message type.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://github.com/anybotics/grid_map",
      "type": "website"
    },
    {
      "uri": "http://github.com/anybotics/grid_map/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "grid_map",
    "url": "https://github.com/ANYbotics/grid_map.git",
    "branch": "jazzy"
  },
  "dependencies": {
    "build": [
      "grid_map_cmake_helpers"
    ],
    "buildtool": [
      "ament_cmake"
    ],
    "build_and_runtime": [
      "rclcpp",
      "std_msgs",
      "geometry_msgs",
      "rosidl_default_generators"
    ],
    "depended_on_by": [
      "grid_map",
      "grid_map_demos",
      "grid_map_filters",
      "grid_map_loader",
      "grid_map_pcl",
      "grid_map_ros",
      "grid_map_rviz_plugin",
      "grid_map_visualization"
    ]
  },
  "messages": {
    "GridMap": {
      "description": "Header (time and frame)",
      "raw": "# Header (time and frame)\nstd_msgs/Header header\n\n# Grid map header\nGridMapInfo info\n\n# Grid map layer names.\nstring[] layers\n\n# Grid map basic layer names (optional). The basic layers\n# determine which layers from `layers` need to be valid\n# in order for a cell of the grid map to be valid.\nstring[] basic_layers\n\n# Grid map data.\nstd_msgs/Float32MultiArray[] data\n\n# Row start index (default 0).\nuint16 outer_start_index\n\n# Column start index (default 0).\nuint16 inner_start_index\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "GridMapInfo",
          "name": "info",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string[]",
          "name": "layers",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string[]",
          "name": "basic_layers",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "std_msgs/Float32MultiArray[]",
          "name": "data",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "outer_start_index",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint16",
          "name": "inner_start_index",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GridMapInfo": {
      "description": "Resolution of the grid [m/cell].",
      "raw": "# Resolution of the grid [m/cell].\nfloat64 resolution\n\n# Length in x-direction [m].\nfloat64 length_x\n\n# Length in y-direction [m].\nfloat64 length_y\n\n# Pose of the grid map center in the frame defined in `header` [m].\ngeometry_msgs/Pose pose",
      "fields": [
        {
          "type": "float64",
          "name": "resolution",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "length_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "length_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "geometry_msgs/Pose",
          "name": "pose",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "services": {
    "GetGridMap": {
      "description": "Frame id of the submap position request.",
      "raw": "# Frame id of the submap position request.\nstring frame_id\n\n# Requested submap position in x-direction [m].\nfloat64 position_x\n  \n# Requested submap position in y-direction [m].\nfloat64 position_y\n\n# Requested submap length in x-direction [m].\nfloat64 length_x\n  \n# Requested submap width in y-direction [m].\nfloat64 length_y\n\n# Requested layers. If empty, get all layers.\nstring[] layers\n\n---\n\n# Submap\ngrid_map_msgs/GridMap map\n",
      "request_fields": [
        {
          "type": "string",
          "name": "frame_id",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "position_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "position_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "length_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "length_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string[]",
          "name": "layers",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "grid_map_msgs/GridMap",
          "name": "map",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GetGridMapInfo": {
      "description": "Grid map info",
      "raw": "---\n\n# Grid map info\ngrid_map_msgs/GridMapInfo info\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "grid_map_msgs/GridMapInfo",
          "name": "info",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "ProcessFile": {
      "description": "Absolute file path.",
      "raw": "# Absolute file path.\nstring file_path\n\n# For ROS bags: topic name that should be processed (optional).\nstring topic_name\n\n---\n\n# True if file processing was successful.\nbool success\n",
      "request_fields": [
        {
          "type": "string",
          "name": "file_path",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "topic_name",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "SetGridMap": {
      "description": "map",
      "raw": "# map\ngrid_map_msgs/GridMap map\n\n---\n",
      "request_fields": [
        {
          "type": "grid_map_msgs/GridMap",
          "name": "map",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": []
    }
  },
  "actions": {}
}
