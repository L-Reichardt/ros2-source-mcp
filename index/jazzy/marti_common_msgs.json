    "HealthStatus": {
      "description": "This message is intended for use as a light-weight machine status indicator for robot consumption",
      "raw": "# This message is intended for use as a light-weight machine status indicator for robot consumption\n# whereas Diagnostics are for human consumption\n\nint8 OK=0    # Initialized with no issues\nint8 WARN=1  # Component is operating but the data may be inaccurate or there may be minor problems\nint8 ERROR=2 # Component has encountered a serious problem and cannot or will not operate\nint8 STALE=3 # Uninitialized or cannot determine status\n\nstd_msgs/Header header\n\nint8   status\nstring message\n",
      "fields": [
        {
          "type": "int8",
          "name": "OK",
          "comment": "Initialized with no issues",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "int8",
          "name": "WARN",
          "comment": "Component is operating but the data may be inaccurate or there may be minor problems",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "int8",
          "name": "ERROR",
          "comment": "Component has encountered a serious problem and cannot or will not operate",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "int8",
          "name": "STALE",
          "comment": "Uninitialized or cannot determine status",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int8",
          "name": "status",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "message",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
