{
  "name": "mocap4r2_msgs",
  "version": "0.1.0",
  "description": "Interfaces for Mocap4ROS2 project",
  "license": "Apache License, Version 2.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "mocap4r2_msgs",
