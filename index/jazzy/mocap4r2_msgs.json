        {
          "type": "string[]",
          "name": "sensor_ids",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "battery_level",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "temperature",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Marker": {
      "description": "",
      "raw": "int8 USE_NAME=0\nint8 USE_INDEX=1\nint8 USE_BOTH=2\n\nint8 id_type\nint32 marker_index\nstring marker_name\ngeometry_msgs/Point translation",
