        {
          "type": "geometry_msgs/Point",
          "name": "translation",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Markers": {
      "description": "",
      "raw": "std_msgs/Header header\nuint32 frame_number\nmocap4r2_msgs/Marker[] markers\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
