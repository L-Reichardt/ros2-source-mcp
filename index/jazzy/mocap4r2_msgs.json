        {
          "type": "uint32",
          "name": "frame_number",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "mocap4r2_msgs/Marker[]",
          "name": "markers",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "RigidBodies": {
      "description": "",
      "raw": "std_msgs/Header header\nuint32 frame_number\nmocap4r2_msgs/RigidBody[] rigidbodies\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "frame_number",
          "comment": "",
          "default": null,
          "is_constant": false
