        {
          "type": "int8",
          "name": "USE_NAME",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "int8",
          "name": "USE_INDEX",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "int8",
          "name": "USE_BOTH",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "int8",
          "name": "id_type",
          "comment": "",
          "default": null,
          "is_constant": false
