        {
          "type": "string",
          "name": "link_parent",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32[]",
          "name": "markers",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "actions": {}
}
