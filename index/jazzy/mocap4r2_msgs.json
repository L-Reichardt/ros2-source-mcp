    "branch": "jazzy"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "build_and_runtime": [
      "rclcpp",
      "std_msgs",
      "geometry_msgs",
      "builtin_interfaces",
      "rosidl_default_generators"
    ],
    "depended_on_by": []
  },
  "messages": {
    "ImusInfo": {
      "description": "",
      "raw": "string[] sensor_ids\nfloat32 battery_level\nfloat32 temperature\n",
