{
  "name": "mrpt_libbase",
  "version": "2.15.8",
  "description": "Mobile Robot Programming Toolkit (MRPT) libraries (core C++ libraries).\n  This package contains: mrpt-io, mrpt-serialization, mrpt-random, mrpt-system, mrpt-rtti, mrpt-containers, mrpt-typemeta, mrpt-core, mrpt-random, mrpt-config, mrpt-expr",
  "license": "BSD",
  "build_type": "cmake",
  "deprecated": null,
  "urls": [
    {
