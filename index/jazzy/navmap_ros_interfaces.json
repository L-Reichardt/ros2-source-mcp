{
  "name": "navmap_ros_interfaces",
  "version": "0.3.0",
  "description": "ROS 2 interfaces for NavMap (messages for visualization and layers)",
  "license": "Apache License, Version 2.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "NavMap",
    "url": "https://github.com/EasyNavigation/NavMap.git",
    "branch": "jazzy"
  },
  "dependencies": {
    "buildtool": [
      "ament_cmake"
    ],
