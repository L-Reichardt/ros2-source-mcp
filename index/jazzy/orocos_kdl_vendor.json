      "moveit_core",
      "moveit_kinematics",
      "python_orocos_kdl_vendor",
      "robot_state_publisher",
      "tf2_eigen_kdl",
      "tf2_geometry_msgs",
      "tf2_kdl"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
