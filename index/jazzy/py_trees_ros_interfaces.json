    "OpenBlackboardStream": {
      "description": "Specify a list of variables to watch on the blackboard. These",
      "raw": "# Specify a list of variables to watch on the blackboard. These\n# can be nested variables (e.g. get only the position in an odom\n# message). Typically this service is not used directly, but by the\n# blackboard watcher utility\n\n# list of variables to watch\nstring[] variables\n# restrict the list of variable names to select from those\n# associated with behaviours on the tree tick's visited path\nbool filter_on_visited_path\n# include the activity stream associated with the most recent\n# changes to the blackboard\nbool with_activity_stream\n---\n# topic name that is dynamically created for watching\nstring topic\n",
      "request_fields": [
        {
          "type": "string[]",
          "name": "variables",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "filter_on_visited_path",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "with_activity_stream",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "string",
          "name": "topic",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "OpenSnapshotStream": {
      "description": "Open a snapshot stream.",
      "raw": "##############################################################################\n# Open a snapshot stream.\n#\n# Request\n#   topic_name: (optional) snapshot stream location \n#   parameters: used to configure the contents/rate of the stream\n#\n# Response\n#\n#   topic_name: the topic created for the snapshot stream\n#\n# Note: if the topic_name is not provided the service is expected to\n# create and return a dynamically created snapshot stream on a hidden\n# topic (the topic name will be returned in the response).\n#\n##############################################################################\n\nstring topic_name\nSnapshotStreamParameters parameters\n\n---\n\nstring topic_name\n",
      "request_fields": [
        {
          "type": "string",
          "name": "topic_name",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "SnapshotStreamParameters",
          "name": "parameters",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "string",
          "name": "topic_name",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
