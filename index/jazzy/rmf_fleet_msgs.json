    "MutexGroupRequest": {
      "description": "This message is used to attempt to claim a mutex group. It should be sent",
      "raw": "# This message is used to attempt to claim a mutex group. It should be sent\n# periodically for the entire duration that the claimer needs the mutex because\n# mutex groups have a limited-time leasing period that will timeout if a request\n# heartbeat is not received in some amount of time.\n\n# Name of the mutex group that is being claimed\nstring group\n\n# Name of the agent that is trying to claim the mutex group.\nuint64 claimant\n\n# Time stamp of when the claim request began. The same time stamp should be used\n# for all subsequent heartbeat messages related to this claim. If the claim time\n# changes then this claim will be treated a new claim and may be deprioritized.\n# Earlier claims have priority over later claims.\nbuiltin_interfaces/Time claim_time\n\n# What kind of request is this?\nuint32 mode\n# Request to release the mutex group from this claimer\nuint32 MODE_RELEASE=0\n# Request to lock the mutex group for this claimer\nuint32 MODE_LOCK=1\n",
      "fields": [
        {
          "type": "string",
          "name": "group",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint64",
          "name": "claimant",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "builtin_interfaces/Time",
          "name": "claim_time",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "mode",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "MODE_RELEASE",
          "comment": "",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "uint32",
          "name": "MODE_LOCK",
          "comment": "",
          "default": "1",
          "is_constant": true
        }
      ]
    },
