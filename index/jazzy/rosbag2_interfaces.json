{
  "name": "rosbag2_interfaces",
  "version": "0.26.10",
  "description": "Interface definitions for controlling rosbag2",
  "license": "Apache License 2.0",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "rosbag2",
    "url": "https://github.com/ros2/rosbag2.git",
    "branch": "jazzy"
  },
  "dependencies": {
    "build": [
      "builtin_interfaces"
    ],
    "buildtool": [
      "ament_cmake",
      "rosidl_default_generators"
    ],
    "runtime": [
      "builtin_interfaces",
      "rosidl_default_runtime"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "depended_on_by": [
      "rosbag2_tests",
      "rosbag2_transport"
    ]
  },
  "messages": {
    "ReadSplitEvent": {
      "description": "The full path of the file that was finished and closed",
      "raw": "# The full path of the file that was finished and closed\nstring closed_file\n\n# The full path of the new file that was opened to continue playback\nstring opened_file\n\n# The fully qualified node name of the event sender\nstring node_name\n",
      "fields": [
        {
          "type": "string",
          "name": "closed_file",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "opened_file",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "node_name",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "WriteSplitEvent": {
      "description": "The full path of the file that was finished and closed",
      "raw": "# The full path of the file that was finished and closed\nstring closed_file\n\n# The full path of the new file that was created to continue recording\nstring opened_file\n\n# The fully qualified node name of the event sender\nstring node_name\n",
      "fields": [
        {
          "type": "string",
          "name": "closed_file",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "opened_file",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "node_name",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    }
  },
  "services": {
    "Burst": {
      "description": "",
      "raw": "uint64 num_messages  # Number of messages to burst; zero to burst the whole bag\n---\nuint64 actually_burst  # Number of messages actually burst\n",
      "request_fields": [
        {
          "type": "uint64",
          "name": "num_messages",
          "comment": "Number of messages to burst; zero to burst the whole bag",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "uint64",
          "name": "actually_burst",
          "comment": "Number of messages actually burst",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GetRate": {
      "description": "",
      "raw": "---\nfloat64 rate\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "float64",
          "name": "rate",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "IsDiscoveryRunning": {
      "description": "True if discovery is running, false otherwise",
      "raw": "---\n# True if discovery is running, false otherwise\nbool running\n\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "bool",
          "name": "running",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "IsPaused": {
      "description": "",
      "raw": "---\nbool paused\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "bool",
          "name": "paused",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Pause": {
      "description": "",
      "raw": "---\n",
      "request_fields": [],
      "response_fields": []
    },
    "Play": {
      "description": "See rosbag2_transport::PlayOptions::start_offset",
      "raw": "# See rosbag2_transport::PlayOptions::start_offset\nbuiltin_interfaces/Time start_offset\n# See rosbag2_transport::PlayOptions::playback_duration\nbuiltin_interfaces/Duration playback_duration\n# See rosbag2_transport::PlayOptions::playback_until_timestamp\nbuiltin_interfaces/Time playback_until_timestamp\n---\n# returns false when another playback execution is running, otherwise true\nbool success\n",
      "request_fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "start_offset",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "builtin_interfaces/Duration",
          "name": "playback_duration",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "builtin_interfaces/Time",
          "name": "playback_until_timestamp",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "PlayNext": {
      "description": "",
      "raw": "---\nbool success  # can only play-next while playback is paused\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "can only play-next while playback is paused",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Record": {
      "description": "if provided, it will override the storage_options.uri provided during construction.",
      "raw": "# if provided, it will override the storage_options.uri provided during construction.\n# Empty by default.\nstring uri\n---\n# Return code. Returns 1 when recording is already running or in case of error, otherwise 0.\nint32 return_code\n# Error string. Empty if no error occurred.\nstring error_string\n",
      "request_fields": [
        {
          "type": "string",
          "name": "uri",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "int32",
          "name": "return_code",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "error_string",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Resume": {
      "description": "",
      "raw": "---\n",
      "request_fields": [],
      "response_fields": []
    },
    "Seek": {
      "description": "",
      "raw": "builtin_interfaces/Time time\n---\nbool success  # return true if valid time in bag duration, and successful seek\n",
      "request_fields": [
        {
          "type": "builtin_interfaces/Time",
          "name": "time",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "return true if valid time in bag duration, and successful seek",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "SetRate": {
      "description": "",
      "raw": "float64 rate\n---\nbool success  # true if valid rate (> 0) was set\n",
      "request_fields": [
        {
          "type": "float64",
          "name": "rate",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "true if valid rate (> 0) was set",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Snapshot": {
      "description": "",
      "raw": "---\nbool success\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "SplitBagfile": {
      "description": "",
      "raw": "---\n",
      "request_fields": [],
      "response_fields": []
    },
    "StartDiscovery": {
      "description": "Return code. Returns 1 when discovery is already running or in case of error, otherwise 0.",
      "raw": "---\n# Return code. Returns 1 when discovery is already running or in case of error, otherwise 0.\nint32 return_code\n# Error string. Empty if no error occurred.\nstring error_string\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "int32",
          "name": "return_code",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "error_string",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Stop": {
      "description": "",
      "raw": "---\n",
      "request_fields": [],
      "response_fields": []
    },
    "StopDiscovery": {
      "description": "Return code. Returns 1 when discovery is not running, otherwise 0.",
      "raw": "---\n# Return code. Returns 1 when discovery is not running, otherwise 0.\nint32 return_code\n# Error string. Empty if no error occurred.\nstring error_string\n",
      "request_fields": [],
      "response_fields": [
        {
          "type": "int32",
          "name": "return_code",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "error_string",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "TogglePaused": {
      "description": "",
      "raw": "---\n",
      "request_fields": [],
      "response_fields": []
    }
  },
  "actions": {}
}
