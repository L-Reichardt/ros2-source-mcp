{
  "name": "wireless_msgs",
  "version": "1.1.5",
  "description": "Messages for describing a wireless network such as bitrate, essid, and link quality.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "wireless",
    "url": "https://github.com/clearpathrobotics/wireless.git",
    "branch": "humble"
  },
  "dependencies": {
    "build": [
      "builtin_interfaces",
      "rosidl_default_generators"
    ],
    "buildtool": [
      "ament_cmake"
    ],
    "runtime": [
      "builtin_interfaces",
      "rosidl_default_runtime"
    ],
    "build_and_runtime": [
