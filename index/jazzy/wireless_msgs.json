          "type": "float32",
          "name": "bitrate",
          "comment": "Mb/s",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int16",
          "name": "txpower",
          "comment": "dBm",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "link_quality_raw",
          "comment": "",
          "default": null,
          "is_constant": false
