          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "frequency",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Network": {
      "description": "",
      "raw": "string type\nstring essid\nstring mac\nstring mode\nstring frequency\nbool encryption\n",
      "fields": [
        {
          "type": "string",
          "name": "type",
          "comment": "",
          "default": null,
          "is_constant": false
