          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "latency_avg",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32[]",
          "name": "latency_measurements",
          "comment": "",
          "default": null,
          "is_constant": false
        }
