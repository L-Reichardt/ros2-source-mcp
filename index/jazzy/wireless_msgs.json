        {
          "type": "float32",
          "name": "link_quality",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int16",
          "name": "signal_level",
          "comment": "dBm",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int16",
          "name": "noise_level",
          "comment": "dBm",
          "default": null,
          "is_constant": false
