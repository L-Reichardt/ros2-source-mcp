          "name": "encryption",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Quality": {
      "description": "",
      "raw": "std_msgs/Header header\n\nuint16 messages_received\nuint16 messages_missed\n\nuint32 total_length\nuint32[] message_lengths\n\nfloat32 latency_avg\nfloat32[] latency_measurements\n",
