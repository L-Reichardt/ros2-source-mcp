    "GnssInsOrientation": {
      "description": "GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message",
      "raw": "# GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message\n#\n# Represents a 3D orientation in a global coordinate system.\n#\n# ROS uses ENU axes convention (East, North, Up) corresponds to (x, y, z).\n\n# Quaternion representation of the orientation.\ngeometry_msgs/Quaternion orientation\n\n# Root mean square error of the rotation [rad]\n# (x, y, z) axes corresponding to (roll, pitch, yaw)\nfloat32 rmse_rotation_x\nfloat32 rmse_rotation_y\nfloat32 rmse_rotation_z\n",
      "fields": [
        {
          "type": "geometry_msgs/Quaternion",
          "name": "orientation",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "rmse_rotation_x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "rmse_rotation_y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "rmse_rotation_z",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GnssInsOrientationStamped": {
      "description": "GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message",
      "raw": "# GNSS(Global Navigation Satellite System) INS(Inertial Navigation System) orientation message\n#\n# Represents a 3D orientation in a global coordinate system with coordinate frame and timestamp.\n\n# Timestamp this reading was received by the INS sensor\n# Frame is expected to be of the INS device\nstd_msgs/Header header\n\nGnssInsOrientation orientation\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "GnssInsOrientation",
          "name": "orientation",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
