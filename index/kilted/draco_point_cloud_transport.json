{
  "name": "draco_point_cloud_transport",
  "version": "5.0.4",
  "description": "draco_point_cloud_transport provides a plugin to point_cloud_transport for sending point clouds\n    encoded with KD tree compression.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "https://github.com/ctu-vras/draco_point_cloud_transport",
      "type": "repository"
    },
    {
      "uri": "https://wiki.ros.org/draco_point_cloud_transport",
      "type": "website"
    },
    {
      "uri": "https://github.com/ctu-vras/draco_point_cloud_transport/issues",
      "type": "bugtracker"
    }
  ],
  "repo": {
    "name": "point_cloud_transport_plugins",
    "url": "https://github.com/ros-perception/point_cloud_transport_plugins.git",
    "branch": "kilted"
  },
  "dependencies": {
    "build": [
      "libdraco-dev",
      "pluginlib"
    ],
    "buildtool": [
      "ament_cmake"
    ],
    "runtime": [
      "libdraco-dev",
      "pluginlib"
    ],
    "test": [
      "ament_lint_auto",
      "ament_lint_common"
    ],
    "build_and_runtime": [
      "point_cloud_interfaces",
      "point_cloud_transport",
      "rclcpp",
      "rcpputils",
      "sensor_msgs",
      "std_msgs"
    ],
    "depended_on_by": [
      "point_cloud_transport_plugins"
    ]
  },
  "messages": {},
  "services": {},
  "actions": {}
}
