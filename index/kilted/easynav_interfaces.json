          "name": "FEEDBACK",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "FINISHED",
          "comment": "",
          "default": "4",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "FAILED",
          "comment": "",
          "default": "5",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "CANCEL",
          "comment": "",
          "default": "6",
          "is_constant": true
        },
        {
