        {
          "type": "float32",
          "name": "r_foot_back_right",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Gyroscope": {
      "description": "Holds Gyroscope information for a NAO V6",
      "raw": "# Holds Gyroscope information for a NAO V6\n# Units are in rad/s\n# Follows conventions here: http://doc.aldebaran.com/2-1/family/robots/inertial_robot.html\n\n# x is rotating right / left vertically (from robots perspective)\n# - Falling right (from robot's perspective) is positive\n# - Falling left (from robot's perspective) is negative\nfloat32 x\n\n# y is rotating over toes and heels\n# - Rotating over toes is positive\n# - Rotating over heels is negative\nfloat32 y\n\n# NOTE: This is flipped on the V5, and because of that all of gyroscopez may be inverted in a lot of codebases.\n# z is rotating left / right horizontally (from robot's perspective)\n# - Turning to the left is positive\n# - Turning to the right is negative\nfloat32 z",
      "fields": [
        {
          "type": "float32",
          "name": "x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "z",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
