  "messages": {
    "Accelerometer": {
      "description": "Holds Accelerometer information for a NAO V6",
      "raw": "# Holds Accelerometer information for a NAO V6\n# Units are in m/s^2\n# Follows conventions here: http://doc.aldebaran.com/2-1/family/robots/inertial_robot.html\n# Note that gravity is measured by an accelerometer.\n# When standing, the robot will measure 9.8m/s^2 POSITIVE in the z-direction, since its \n# receiving an acceleration upwards from the floor when compared to a freefall state.\n\n# x is moving forwards / backwards (from robots perspective)\n# - Forwards is positive\n# - Backwards is negative\nfloat32 x\n\n# y is moving left / right (from robot's perspective)\n# - Left is positive\n# - Right is negative\nfloat32 y\n\n# z is moving up / down\n# - Standing straight is negative\n# - Upside down is positive\nfloat32 z",
      "fields": [
        {
          "type": "float32",
          "name": "x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "y",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "z",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Angle": {
      "description": "Holds Angle information for a NAO V6",
      "raw": "# Holds Angle information for a NAO V6\n# Units are in rad\n\n# x axis is rotating Nao left / right (vertical rotation)\n# - If Nao is facing towards you, rotating it to the left is positive\n# - Conversely, rotating it to the right is negative\nfloat32 x\n\n# y axis is rotating Nao back / forward\n# - Forward is positive angle\n# - Backwards is negative angle\nfloat32 y",
      "fields": [
        {
          "type": "float32",
          "name": "x",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "y",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "Battery": {
      "description": "",
      "raw": "float32 charge  # 0% - 100%\nbool charging  # True if robot is getting charged\nfloat32 current  # In Amperes, negative for discharge, positive for charge\nfloat32 temperature  # Celcius (°C)",
      "fields": [
        {
          "type": "float32",
          "name": "charge",
          "comment": "0% - 100%",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "charging",
          "comment": "True if robot is getting charged",
          "default": null,
          "is_constant": false
