    "FSR": {
      "description": "FSR stands for Force Sensitive Resistors.",
      "raw": "# FSR stands for Force Sensitive Resistors.\n# These sensors measure a resistance change according to the pressure applied.\n# Units used are in Newtons (equivalently kg/m/s^2)\n# http://doc.aldebaran.com/2-1/family/robots/fsr_robot.html\n\nfloat32 l_foot_front_left\nfloat32 l_foot_front_right\nfloat32 l_foot_back_left\nfloat32 l_foot_back_right\nfloat32 r_foot_front_left\nfloat32 r_foot_front_right\nfloat32 r_foot_back_left\nfloat32 r_foot_back_right",
      "fields": [
