        },
        {
          "type": "uint8",
          "name": "n_satellites",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "GpgsvSatellite[]",
          "name": "satellites",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "GpgsvSatellite": {
      "description": "Satellite data structure used in GPGSV messages",
      "raw": "# Satellite data structure used in GPGSV messages\n\n# PRN number of the satellite\n# GPS = 1..32\n# SBAS = 33..64\n# GLO = 65..96\nuint8 prn\n\n# Elevation, degrees. Maximum 90\nuint8 elevation\n\n# Azimuth, True North degrees. [0, 359]\nuint16 azimuth\n\n# Signal to noise ratio, 0-99 dB. -1 when null in NMEA sentence (not tracking)\nint8 snr\n",
      "fields": [
