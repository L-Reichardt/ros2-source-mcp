          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint64",
          "name": "min_latency",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint64",
          "name": "max_latency",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint64",
          "name": "minor_pagefaults",
          "comment": "",
          "default": null,
          "is_constant": false
