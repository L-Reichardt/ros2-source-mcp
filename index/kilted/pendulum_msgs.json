        {
          "type": "float64",
          "name": "position",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "velocity",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64",
          "name": "effort",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "RttestResults": {
      "description": "",
      "raw": "builtin_interfaces/Time stamp\n\nJointCommand command\nJointState state\n\nuint64 cur_latency\nfloat64 mean_latency\nuint64 min_latency\nuint64 max_latency\nuint64 minor_pagefaults \nuint64 major_pagefaults \n",
