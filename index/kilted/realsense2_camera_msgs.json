      "description": "RGBD Message",
      "raw": "# RGBD Message\nstd_msgs/Header header\nsensor_msgs/CameraInfo rgb_camera_info\nsensor_msgs/CameraInfo depth_camera_info\nsensor_msgs/Image rgb\nsensor_msgs/Image depth\n",
