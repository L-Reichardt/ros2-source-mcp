        {
          "type": "float64[3]",
          "name": "translation",
          "comment": "Three-element translation vector, in meters",
          "default": null,
          "is_constant": false
        }
      ]
    },
    "IMUInfo": {
      "description": "header.frame_id is either set to \"imu_accel\" or \"imu_gyro\"",
      "raw": "# header.frame_id is either set to \"imu_accel\" or \"imu_gyro\"\n# to distinguish between \"accel\" and \"gyro\" info.\nstd_msgs/Header header\nfloat64[12] data\nfloat64[3] noise_variances\nfloat64[3] bias_variances\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float64[12]",
          "name": "data",
