{
  "name": "slam_toolbox",
  "version": "2.9.0",
  "description": "This package provides a sped up improved slam karto with updated SDK and visualization and modification toolsets",
  "license": "LGPL",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
  "repo": {
    "name": "slam_toolbox",
    "url": "https://github.com/SteveMacenski/slam_toolbox.git",
    "branch": "kilted"
  },
  "dependencies": {
    "build": [
      "pluginlib",
      "eigen",
      "message_filters",
      "nav_msgs",
