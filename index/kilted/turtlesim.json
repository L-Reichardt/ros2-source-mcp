{
  "name": "turtlesim",
  "version": "1.9.4",
  "description": "turtlesim is a tool made for teaching ROS and ROS packages.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [
    {
      "uri": "http://www.ros.org/wiki/turtlesim",
      "type": "website"
    },
    {
      "uri": "https://github.com/ros/ros_tutorials/issues",
      "type": "bugtracker"
    },
    {
      "uri": "https://github.com/ros/ros_tutorials",
      "type": "repository"
    }
  ],
  "repo": {
    "name": "ros_tutorials",
