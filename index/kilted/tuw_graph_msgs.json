{
  "name": "tuw_graph_msgs",
  "version": "0.2.5",
  "description": "The tuw_graph_msgs package contains messages for sending graphs.",
  "license": "BSD",
  "build_type": "ament_cmake",
  "deprecated": null,
  "urls": [],
