          "is_constant": true
        }
      ]
    },
    "State": {
      "description": "",
      "raw": "int64 step\nint32[] list_node_open\nint32[] list_edge_open\nstd_msgs/ColorRGBA[] color_open\nint32[] list_node_closed\nint32[] list_edge_closed\nstd_msgs/ColorRGBA[] color_closed",
      "fields": [
