      "raw": "\nuint32 id                     # Segment id\nuint8 type                    # Segment type\n                              # NA      = 0\n                              # LINE    = 1\n                              # ARC     = 2\n                              # SPIROS  = 3\n                              # SPLINE  = 4\nuint8 orientation             # Segment orientation\n                              # CLOCKWISE  = 0\n                              # COUNTER_CLOCKWISE  = 1\nuint8 motion_type             # Motion type\n                              # NA = 0\n                              # FLAT = 1\n                              # DWA_SLOW = 2\n                              # DWA_FAST = 3\n                              # MPC_SLOW = 4\n                              # MPC_FAST = 5\n                              # PI_SLOW = 6\n                              # PI_FAST = 7\ngeometry_msgs/Pose start\ngeometry_msgs/Pose end\ngeometry_msgs/Pose center    \nint8 level\n\n",
