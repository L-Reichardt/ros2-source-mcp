    "ControllerState": {
      "description": "Progress/State of a trajectory controller",
      "raw": "#################################################################\n## Progress/State of a trajectory controller\n#################################################################\n\n\nstd_msgs/Header header         # header, ...\nint32  state                   # controller state\nuint32 progress                # passed waypoints \nuint32 progress_in_relation_to # id / seq nummer in oder to put the progess in realtion to a waypoint msg or spline msg\nstring info                    # details on the controller state in human form for debugging only \n\n\n\nint32 STATE_IDLE = 0                 # controller is inactive\nint32 STATE_DRIVING = 1              # controller is driving and following a path\nint32 STATE_FINISHED = 2             # controller finished a path\n",
      "fields": [
        {
          "type": "std_msgs/Header",
          "name": "header",
          "comment": "header, ...",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "state",
          "comment": "controller state",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "progress",
          "comment": "passed waypoints",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint32",
          "name": "progress_in_relation_to",
          "comment": "id / seq nummer in oder to put the progess in realtion to a waypoint msg or spline msg",
          "default": null,
          "is_constant": false
        },
        {
          "type": "string",
          "name": "info",
          "comment": "details on the controller state in human form for debugging only",
          "default": null,
          "is_constant": false
        },
        {
          "type": "int32",
          "name": "STATE_IDLE",
          "comment": "controller is inactive",
          "default": "0",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "STATE_DRIVING",
          "comment": "controller is driving and following a path",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "int32",
          "name": "STATE_FINISHED",
          "comment": "controller finished a path",
          "default": "2",
          "is_constant": true
        }
      ]
    },
