    "SetForceMode": {
      "description": "A 6d pose that defines the force frame. Must be static relative to the robot's base frame.",
      "raw": "# A 6d pose that defines the force frame. Must be static relative to the robot's base frame.\ngeometry_msgs/PoseStamped task_frame\n\n# 1 means that the robot will be compliant in the corresponding axis of the task frame\nbool selection_vector_x 0 \nbool selection_vector_y 0\nbool selection_vector_z 0\nbool selection_vector_rx 0\nbool selection_vector_ry 0\nbool selection_vector_rz 0\n\n# The forces/torques the robot will apply to its environment. For geometric interpretation, please\n# see parameter `type`\ngeometry_msgs/Wrench wrench\n\n# An integer [1;3] specifying how the robot interprets the force frame\n# 1: The force frame is transformed in a way such that its y-axis is aligned with a vector pointing\n#    from the robot tcp towards the origin of the force frame.\n# 2: The force frame is not transformed.\n# 3: The force frame is transformed in a way such that its x-axis is the projection of the robot tcp\n#     velocity vector onto the x-y plane of the force frame.\nuint8 type 2\n# Type constants:\nuint8 TCP_TO_ORIGIN=1\nuint8 NO_TRANSFORM=2\nuint8 TCP_VELOCITY_TO_X_Y=3\n\n# Maximum allowed tcp speed (relative to the task frame).\n# PLEASE NOTE: This is only relevant for axes marked as compliant in the selection_vector\ngeometry_msgs/Twist speed_limits\n\n# For non-compliant axes, these values are the maximum allowed deviation along/about an axis\n# between the actual tcp position and the one set by the program.\nfloat32[6] deviation_limits [0.01, 0.01, 0.01, 0.01, 0.01, 0.01]\n\n# Force mode damping factor. Sets the damping parameter in force mode. In range [0;1], default value is 0.025\n# A value of 1 is full damping, so the robot will decelerate quickly if no force is present. A value of 0\n# is no damping, here the robot will maintain the speed.\nfloat32 damping_factor 0.025\n\n# Force mode gain scaling factor. Scales the gain in force mode. scaling parameter is in range [0;2], default is 0.5. \n# A value larger than 1 can make force mode unstable, e.g. in case of collisions or pushing against hard surfaces.\nfloat32 gain_scaling 0.5\n---\nbool success\n",
      "request_fields": [
        {
          "type": "geometry_msgs/PoseStamped",
          "name": "task_frame",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "selection_vector_x",
          "comment": "",
          "default": "0",
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "selection_vector_y",
          "comment": "",
          "default": "0",
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "selection_vector_z",
          "comment": "",
          "default": "0",
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "selection_vector_rx",
          "comment": "",
          "default": "0",
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "selection_vector_ry",
          "comment": "",
          "default": "0",
          "is_constant": false
        },
        {
          "type": "bool",
          "name": "selection_vector_rz",
          "comment": "",
          "default": "0",
          "is_constant": false
        },
        {
          "type": "geometry_msgs/Wrench",
          "name": "wrench",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "type",
          "comment": "",
          "default": "2",
          "is_constant": false
        },
        {
          "type": "uint8",
          "name": "TCP_TO_ORIGIN",
          "comment": "",
          "default": "1",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "NO_TRANSFORM",
          "comment": "",
          "default": "2",
          "is_constant": true
        },
        {
          "type": "uint8",
          "name": "TCP_VELOCITY_TO_X_Y",
          "comment": "",
          "default": "3",
          "is_constant": true
        },
        {
          "type": "geometry_msgs/Twist",
          "name": "speed_limits",
          "comment": "",
          "default": null,
          "is_constant": false
        },
        {
          "type": "float32[6]",
          "name": "deviation_limits",
          "comment": "",
          "default": "[0.01, 0.01, 0.01, 0.01, 0.01, 0.01]",
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "damping_factor",
          "comment": "",
          "default": "0.025",
          "is_constant": false
        },
        {
          "type": "float32",
          "name": "gain_scaling",
          "comment": "",
          "default": "0.5",
          "is_constant": false
        }
      ],
      "response_fields": [
        {
          "type": "bool",
          "name": "success",
          "comment": "",
          "default": null,
          "is_constant": false
        }
      ]
