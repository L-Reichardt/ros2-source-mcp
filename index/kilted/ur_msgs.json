    "SetGravity": {
      "description": "The direction of the gravity experienced by the robot, pointing towards the earth’s centre.",
      "raw": "# The direction of the gravity experienced by the robot, pointing towards the earth’s centre.\n# The UR Robot driver will transform this to the robot frame automatically\ngeometry_msgs/Vector3Stamped gravity\n---\nbool success\nstring status\n",
